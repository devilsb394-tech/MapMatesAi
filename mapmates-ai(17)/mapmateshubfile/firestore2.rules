rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // PILLAR 3: PRIMITIVE DEFINITIONS
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email_verified == null);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'devilsb394@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isParticipant(participants) {
      return isSignedIn() && request.auth.uid in participants;
    }

    // ==========================================
    // COLLECTIONS
    // ==========================================

    match /admins/{uid} {
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
      
      match /friends/{friendId} {
        allow read, write: if isSignedIn();
      }
      match /likes/{likeId} {
        allow read, write: if isSignedIn();
      }
      match /views/{viewId} {
        allow read, write: if isSignedIn();
      }
      match /path_points/{pointId} {
        allow read, write: if isSignedIn();
      }
    }

    match /destinies/{destinyId} {
      allow read, write: if isSignedIn();
    }

    match /labels/{labelId} {
      allow read, write: if isSignedIn();
    }

    match /parentChildPaths/{pathId} {
      allow read, write: if isSignedIn();
    }

    match /destinyConfigs/{configId} {
      allow read, write: if isSignedIn();
    }

    match /help_signals/{signalId} {
      allow read, write: if isSignedIn();
    }

    match /moments/{momentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    match /conversations/{convId} {
      allow read: if isSignedIn() && isParticipant(existing().participants);
      allow create: if isSignedIn() && isParticipant(incoming().participants);
      allow update: if isSignedIn() && isParticipant(existing().participants);
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && isParticipant(get(/databases/$(database)/documents/conversations/$(convId)).data.participants);
      }
    }

    match /friendRequests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /history/{historyId} {
      allow read: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
    }

    match /ratings/{ratingId} {
      allow read, write: if isSignedIn();
    }

    match /flash_sales/{saleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /app_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /shopping_lists/{listId} {
      allow get, list, write: if isSignedIn();
    }

    match /bids/{bidId} {
      allow get, list, write: if isSignedIn();
    }

    match /stock_queries/{queryId} {
      allow get, list, write: if isSignedIn();
    }

    match /stock_replies/{replyId} {
      allow get, list, write: if isSignedIn();
    }

    match /delivery_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /premiumPayments/{paymentId} {
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /mates/{mateId} {
      allow read, write: if isSignedIn();
    }

    match /calls/{callId} {
      allow read, write: if isSignedIn();
      match /callerCandidates/{candId} {
        allow read, write: if isSignedIn();
      }
      match /calleeCandidates/{candId} {
        allow read, write: if isSignedIn();
      }
    }

    match /userLabelStats/{userId} {
      allow read, write: if isSignedIn();
    }

    match /leaderboard/{scoreId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (scoreId == request.auth.uid || isAdmin());
    }

    match /userFeatureStats/{statId} {
      allow read, write: if isSignedIn();
    }

    match /test/{docId} {
      allow read, write: if isSignedIn();
    }

    match /ai_sync/{syncId} {
      allow read, write: if isSignedIn();
    }
  }
}
